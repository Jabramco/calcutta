# Copy to .env and fill in values. For Vercel, set these in Project → Settings → Environment Variables.
# This app does NOT require the "Prisma Postgres" integration—use any Postgres (Neon, Supabase, Vercel Postgres, etc.).

# Database (required). Use the same value for both if your provider gives only one URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT signing secret (required for login/sessions). Use a long random string in production.
JWT_SECRET="your-secret-key-change-in-production"

# Optional
# NODE_ENV=production

# When "true", /auction is read-only (no bids, admin controls, or auto-sell). Remove or set false for next auction.
# NEXT_PUBLIC_AUCTION_READONLY=true

# Auto-sync tournament wins from ESPN (Vercel Cron: every 15 min). Must match the secret in Vercel → Cron.
# CRON_SECRET="generate-a-long-random-string"
# Optional: defaults to current UTC year if unset (set during March Madness, e.g. 2026).
# TOURNAMENT_IMPORT_YEAR=2026
